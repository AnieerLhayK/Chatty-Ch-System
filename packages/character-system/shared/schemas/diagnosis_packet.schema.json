{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "diagnosis_packet.schema.json",
  "title": "Diagnosis Packet",
  "type": "object",
  "required": [
    "diagnosis_id",
    "created_at",
    "source_character",
    "source_skill",
    "character_context",
    "task_type",
    "user_feedback",
    "failed_output_excerpt",
    "expected_style_direction",
    "drift_types",
    "failed_layer",
    "evidence",
    "severity",
    "suggested_patch_scope",
    "do_not_touch",
    "related_shared_protocols",
    "next_owner"
  ],
  "properties": {
    "diagnosis_id": { "type": "string", "pattern": "^DIAG-[0-9]{8}-[0-9]{3}$" },
    "record_path": { "type": "string" },
    "created_at": { "type": "string" },
    "source_character": { "type": "string" },
    "source_skill": { "type": "string" },
    "character_context": {
      "type": "object",
      "required": [
        "status",
        "character_id",
        "load_evidence",
        "context_warning",
        "user_override",
        "impact"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["confirmed", "unconfirmed", "missing"] },
        "character_id": { "type": "string" },
        "load_evidence": { "type": "string" },
        "context_warning": { "type": "boolean" },
        "user_override": { "type": "boolean" },
        "impact": { "type": "string" }
      },
      "additionalProperties": false
    },
    "source_case": { "type": "string" },
    "task_type": { "type": "string" },
    "user_feedback": { "type": "string" },
    "failed_output_excerpt": { "type": "string" },
    "expected_style_direction": { "type": "string" },
    "drift_types": { "type": "array", "items": { "type": "string" } },
    "failed_layer": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "string" },
    "severity": { "type": "string" },
    "suggested_patch_scope": { "type": "string" },
    "do_not_touch": { "type": "string" },
    "related_shared_protocols": { "type": "array", "items": { "type": "string" } },
    "next_owner": { "type": "string" }
  },
  "additionalProperties": false
}
